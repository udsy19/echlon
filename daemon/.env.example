# Copy to .env and fill in. Loaded automatically by python-dotenv.

# --- Claude (default driver) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Provider selection (optional; defaults to anthropic) ---
# ECHLON_PROVIDER=anthropic
# ECHLON_MODEL_ID=anthropic/claude-opus-4-8     # or anthropic/claude-sonnet-4-6 (cheaper, agentic workhorse)

# --- Run on an open-source model instead (Phase 3) ---
# Prereq: `ollama serve` running, and `ollama pull <model>`.
# ECHLON_PROVIDER=ollama
# ECHLON_MODEL_ID=ollama_chat/qwen2.5-coder:7b   # recommended for CodeAct
# ECHLON_MODEL_ID=ollama_chat/qwen2.5-coder:3b   # light option (proven on this loop)
# ECHLON_API_BASE=http://localhost:11434

# --- Agent ---
# ECHLON_WORKSPACE=./workspace
# ECHLON_MAX_STEPS=30
